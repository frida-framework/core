{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.frida.dev/template-integrity.schema.json",
  "title": "Frida Template Integrity Manifest",
  "type": "object",
  "required": [
    "version",
    "templates"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "file",
          "sha256"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
