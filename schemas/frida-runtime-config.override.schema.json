{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.frida.dev/frida-runtime-config.override.schema.json",
  "title": "Frida Runtime Config Override",
  "description": "User-owned partial runtime config overrides from .frida/config.yaml",
  "type": "object",
  "properties": {
    "version": {
      "type": "string"
    },
    "APP_CONTRACT_SSOT": {
      "type": "string",
      "enum": [
        "REPO.LOCAL",
        "REPO.WIKI"
      ]
    },
    "reporting": {
      "type": "object",
      "properties": {
        "collect_in_repo": {
          "type": "boolean",
          "const": true
        },
        "repo_path": {
          "type": "string",
          "minLength": 1
        },
        "file_ext": {
          "type": "string",
          "const": ".yaml"
        },
        "filename_pattern": {
          "type": "string",
          "const": "<unixtime_ms>_<profile_id>_<task_or_run>.yaml"
        },
        "exists_check": {
          "type": "boolean",
          "const": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
