{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.frida.dev/frida-contract.schema.json",
  "title": "Frida Contract Schema v3.1",
  "description": "Schema for the consolidated Frida core contract. 32 required engine blocks + optional app blocks.",
  "type": "object",
  "required": [
    "meta",
    "core",
    "PATHS",
    "ZONES"
  ],
  "properties": {
    "CANON_META": {
      "type": "object",
      "required": [
        "id",
        "version",
        "owner",
        "updated_at",
        "scope"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "scope": {
          "type": "object",
          "required": [
            "repository",
            "package",
            "purpose"
          ],
          "properties": {
            "repository": {
              "type": "string"
            },
            "package": {
              "type": "string"
            },
            "purpose": {
              "type": "string"
            }
          }
        }
      }
    },
    "CANON_UNIQUENESS": {
      "type": "object",
      "required": [
        "rule",
        "control"
      ],
      "properties": {
        "rule": {
          "type": "string"
        },
        "control": {
          "type": "object",
          "required": [
            "enforcement",
            "fail_on_duplicate"
          ],
          "properties": {
            "enforcement": {
              "type": "string"
            },
            "fail_on_duplicate": {
              "type": "boolean"
            },
            "warning_code": {
              "type": "string"
            }
          }
        },
        "first_rule": {
          "type": "boolean"
        },
        "strictness_freeze": {
          "type": "object"
        },
        "projection_rule": {
          "type": "object"
        }
      }
    },
    "meta": {
      "type": "object",
      "required": [
        "schemaVersion",
        "mode"
      ],
      "properties": {
        "schemaVersion": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "const": "schema"
        },
        "canonArtifactRef": {
          "type": "string"
        }
      }
    },
    "core": {
      "type": "object",
      "required": [
        "selectorGrammar",
        "generatorPipelineContracts",
        "pathRefs",
        "outputContracts"
      ],
      "properties": {
        "canonicalSourceBlocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "contractSourceBlocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "contracticalSourceBlocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "selectorGrammar": {
          "type": "string",
          "const": "jsonpath-lite"
        },
        "generatorPipelineContracts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "pathRefs": {
          "type": "object",
          "required": [
            "templatesFrida",
            "templatesDocs"
          ],
          "properties": {
            "canonArtifact": {
              "type": "string"
            },
            "templatesFrida": {
              "type": "string"
            },
            "templatesDocs": {
              "type": "string"
            }
          }
        },
        "outputContracts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "FRIDA_SCHEMA_SUPPORT": {
      "type": "object",
      "required": [
        "schema_version",
        "path_rules"
      ],
      "properties": {
        "schema_version": {
          "type": "object",
          "required": [
            "supported"
          ]
        },
        "path_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "text"
            ]
          }
        },
        "guards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/triggerGuardEntry"
          }
        }
      }
    },
    "FRIDA_ARCHITECTURE_DECISIONS": {
      "type": "object",
      "required": [
        "decisions"
      ],
      "properties": {
        "decisions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "title",
              "status"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "ACCEPTED",
                  "PROPOSED",
                  "DEPRECATED"
                ]
              },
              "decision": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "FRIDA_FOUNDATION_PRINCIPLES": {
      "type": "object",
      "required": [
        "principles"
      ],
      "properties": {
        "development_sequence": {
          "type": "object"
        },
        "principles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/principleEntry"
          }
        },
        "migration_rule": {
          "type": "object"
        }
      }
    },
    "PATHS": {
      "type": "object",
      "properties": {
        "scaffold": {
          "type": "object"
        },
        "visual": {
          "type": "object"
        },
        "normalization": {
          "type": "object",
          "properties": {
            "rules": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "text"
                ]
              }
            }
          }
        }
      }
    },
    "FRIDA_CONFIG_SPEC": {
      "type": "object",
      "required": [
        "config_shape"
      ],
      "properties": {
        "config_shape": {
          "type": "object"
        },
        "source_item_shape": {
          "type": "object"
        },
        "invariants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/invariantEntry"
          }
        },
        "guards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/triggerGuardEntry"
          }
        }
      }
    },
    "FRIDA_ASSEMBLY_PROTOCOL": {
      "type": "object",
      "required": [
        "inputs",
        "outputs",
        "steps"
      ],
      "properties": {
        "inputs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "text"
            ]
          }
        },
        "determinism": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "guards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/triggerGuardEntry"
          }
        }
      }
    },
    "FRIDA_REFS": {
      "type": "object",
      "required": [
        "suffix",
        "resolution"
      ],
      "properties": {
        "suffix": {
          "type": "object",
          "required": [
            "single",
            "list"
          ],
          "properties": {
            "single": {
              "type": "string"
            },
            "list": {
              "type": "string"
            }
          }
        },
        "resolution": {
          "type": "object",
          "required": [
            "steps"
          ],
          "properties": {
            "steps": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "text"
                ]
              }
            }
          }
        },
        "guards": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/triggerGuardEntry"
          }
        }
      }
    },
    "FRIDA_CONFIG": {
      "type": "object",
      "required": [
        "paths"
      ],
      "properties": {
        "paths": {
          "type": "object",
          "required": [
            "agents_bootloaderFileRef",
            "specs_rootRef",
            "profiles_rootRef",
            "docs_policyDirRef",
            "docs_referenceDirRef",
            "frida_internalRef",
            "templates_fridaRef",
            "templates_docsRef"
          ]
        },
        "reporting": {
          "type": "object",
          "required": [
            "collect_in_repo",
            "repo_path",
            "file_ext",
            "filename_pattern",
            "exists_check"
          ],
          "properties": {
            "collect_in_repo": {
              "type": "boolean",
              "const": true
            },
            "repo_path": {
              "type": "string",
              "const": ".frida/reports"
            },
            "file_ext": {
              "type": "string",
              "const": ".yaml"
            },
            "filename_pattern": {
              "type": "string",
              "const": "<unixtime_ms>_<profile_id>_<task_or_run>.yaml"
            },
            "exists_check": {
              "type": "boolean",
              "const": false
            },
            "access_validation": {
              "type": "object"
            }
          },
          "additionalProperties": false
        },
        "visual": {
          "type": "object"
        },
        "naming": {
          "type": "object"
        }
      }
    },
    "FRIDA_RUNTIME_CONFIG": {
      "type": "object",
      "required": [
        "file",
        "source_of_truth",
        "generated_from"
      ],
      "properties": {
        "file": {
          "type": "string",
          "const": ".frida/config.yaml"
        },
        "source_of_truth": {
          "type": "string",
          "const": "canon"
        },
        "generated_from": {
          "type": "string",
          "const": "FRIDA_CONFIG.reporting"
        }
      }
    },
    "ZONES": {
      "type": "object",
      "properties": {
        "templates": {
          "$ref": "#/$defs/zoneEntry"
        },
        "non_templates": {
          "$ref": "#/$defs/zoneEntry"
        },
        "zone_resolution": {
          "type": "object",
          "properties": {
            "algorithm": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "step",
                  "action"
                ]
              }
            },
            "invariants": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "verification_policy": {
          "type": "object"
        },
        "routing": {
          "type": "object",
          "properties": {
            "stage": {
              "type": "string"
            },
            "classes": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "match"
                ]
              }
            },
            "rules": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "FRIDA_TASK_PROFILES": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "role",
          "security"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "invariants": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "security": {
            "type": "object"
          }
        }
      }
    },
    "FRIDA_ENFORCEMENT": {
      "type": "object",
      "required": [
        "invariants",
        "policies",
        "triggers"
      ],
      "properties": {
        "invariants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/invariantEntry"
          }
        },
        "policies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/guardEntry"
          }
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/triggerGuardEntry"
          }
        },
        "antitask_spec_ref": {
          "type": "string"
        }
      }
    },
    "FRIDA_AGENT_LIFECYCLE": {
      "type": "object",
      "required": [
        "phases",
        "session"
      ],
      "properties": {
        "phases": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "action"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "action": {
                "type": "string"
              }
            }
          }
        },
        "phase_invariants": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "session": {
          "type": "object",
          "required": [
            "purpose",
            "token_mechanism",
            "zone_scope_hard_check"
          ],
          "properties": {
            "purpose": {
              "type": "string"
            },
            "token_mechanism": {
              "type": "object",
              "required": [
                "acquire",
                "release",
                "timeout"
              ]
            },
            "zone_scope_hard_check": {
              "type": "object",
              "required": [
                "enabled",
                "action",
                "on_violation"
              ]
            },
            "lifecycle": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "step"
                ]
              }
            }
          }
        },
        "interaction_modes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string"
              },
              "allowed_operations": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "forbidden_actions_ref": {
          "type": "string"
        },
        "antitask_spec_ref": {
          "type": "string"
        }
      }
    },
    "FRIDA_ENFORCEMENT_TYPES": {
      "type": "object",
      "required": [
        "types"
      ],
      "properties": {
        "types": {
          "type": "object",
          "required": [
            "nail",
            "chain",
            "ban",
            "drift",
            "session"
          ],
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "FRIDA_REPORTING": {
      "type": "object",
      "required": [
        "file_contractRef"
      ],
      "properties": {
        "file_contractRef": {
          "type": "string",
          "const": "FRIDA_CONFIG.reporting"
        },
        "runtime_configRef": {
          "type": "string",
          "const": "FRIDA_RUNTIME_CONFIG"
        },
        "file_contract": {
          "type": "object",
          "required": [
            "collect_in_repo",
            "repo_path",
            "file_ext",
            "filename_pattern"
          ]
        },
        "access": {
          "type": "object",
          "properties": {
            "create_all_profiles": {
              "type": "boolean"
            },
            "read_only_profiles": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "update_delete_allowed_profiles": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "run_report": {
          "type": "object",
          "properties": {
            "required_on": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "schema_ref": {
              "type": "string"
            },
            "filename_prefix": {
              "type": "string"
            },
            "minimum_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "verification_required_sections": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "FRIDA_VALIDATION_CHECKLIST": {
      "type": "object",
      "required": [
        "contract_consistency",
        "reporting_consistency",
        "visual_consistency",
        "template_integrity",
        "session_consistency",
        "scaffold_consistency"
      ]
    },
    "FRIDA_TEMPLATE_INTEGRITY": {
      "type": "object",
      "required": [
        "hash_algorithm",
        "manifest_path",
        "template_source_dir",
        "checks"
      ],
      "properties": {
        "hash_algorithm": {
          "type": "string",
          "const": "sha256"
        },
        "manifest_format": {
          "type": "string"
        },
        "manifest_path": {
          "type": "string"
        },
        "manifest_schema": {
          "type": "string"
        },
        "template_source_dir": {
          "type": "string"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "rule"
            ]
          }
        },
        "enforcement": {
          "type": "object"
        }
      }
    },
    "FRIDA_CLI": {
      "type": "object",
      "required": [
        "binary",
        "commands",
        "exit_codes",
        "determinism"
      ],
      "properties": {
        "binary": {
          "type": "string"
        },
        "commands": {
          "type": "object",
          "additionalProperties": {
            "type": "object"
          }
        },
        "exit_codes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "determinism": {
          "type": "string"
        },
        "integration": {
          "type": "object",
          "properties": {
            "rules": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "adapter_contract": {
              "type": "object"
            }
          }
        }
      }
    },
    "FRIDA_VISUAL": {
      "type": "object",
      "required": [
        "overlay_format",
        "lod_levels",
        "determinism"
      ],
      "properties": {
        "overlay_format": {
          "type": "string"
        },
        "overlay_pathRef": {
          "type": "string"
        },
        "lod_levels": {
          "type": "object",
          "required": [
            "topology",
            "flow",
            "specification"
          ]
        },
        "determinism": {
          "type": "object"
        },
        "ref_to_edge_mapping": {
          "type": "object"
        },
        "generation_trigger": {
          "type": "string"
        },
        "principles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/principleEntry"
          }
        }
      }
    },
    "FRIDA_GUARD_SPEC": {
      "type": "object",
      "required": [
        "guard_format",
        "actions",
        "triggers"
      ],
      "properties": {
        "guard_format": {
          "type": "object",
          "required": [
            "required_fields"
          ],
          "properties": {
            "required_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "optional_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id"
            ]
          }
        },
        "triggers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "FRIDA_INVARIANT_SPEC": {
      "type": "object",
      "required": [
        "invariant_format"
      ],
      "properties": {
        "invariant_format": {
          "type": "object",
          "required": [
            "required_fields"
          ],
          "properties": {
            "required_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "optional_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "FRIDA_ANTITASK_SPEC": {
      "type": "object",
      "required": [
        "antitask_format",
        "reactions",
        "antitasks"
      ],
      "properties": {
        "antitask_term": {
          "type": "string"
        },
        "antitask_format": {
          "type": "object",
          "required": [
            "required_fields"
          ],
          "properties": {
            "required_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "optional_fields": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "reactions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id"
            ]
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id"
            ]
          }
        },
        "antitasks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "pattern",
              "reaction"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "pattern": {
                "type": "string"
              },
              "reaction": {
                "type": "string",
                "enum": [
                  "HALT",
                  "REDIRECT",
                  "WARN"
                ]
              },
              "redirect_to": {
                "type": "string"
              }
            }
          }
        },
        "report_proof": {
          "type": "object",
          "required": [
            "required",
            "path",
            "required_fields",
            "allowed_status"
          ]
        }
      }
    },
    "FRIDA_INTERFACE_VERIFY": {
      "type": "object",
      "required": [
        "purpose"
      ],
      "properties": {
        "purpose": {
          "type": "string"
        },
        "operations": {
          "type": "object"
        }
      }
    },
    "FRIDA_INTERFACE_UPDATE_SPEC": {
      "type": "object",
      "required": [
