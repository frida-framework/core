{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.frida.dev/frida-canon-index.schema.json",
  "title": "Frida Contract Index",
  "description": "Schema for modular contract index entrypoints used by Frida core and Frida-managed app contracts.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "contract_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "minLength": 1
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/layerEntry"
      }
    },
    "contract_index": {
      "type": "object",
      "required": [
        "layers"
      ],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        },
        "schema": {
          "type": "string",
          "minLength": 1
        },
        "assembled_schema": {
          "type": "string",
          "minLength": 1
        },
        "monolith_fallback": {
          "type": "string",
          "minLength": 1
        },
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/layerEntry"
          }
        }
      }
    }
  },
  "required": [
    "schema_version",
    "contract_id",
    "version"
  ],
  "anyOf": [
    {
      "required": [
        "layers"
      ]
    },
    {
      "required": [
        "contract_index"
      ]
    }
  ],
  "$defs": {
    "layerEntry": {
      "type": "object",
      "required": [
        "id",
        "path",
        "blocks"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "private",
            "mixed"
          ]
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "purpose": {
          "type": "string"
        },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
