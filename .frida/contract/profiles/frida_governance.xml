<agent_instruction id="frida_governance">
  <role>ARCHITECT_AGENT</role>
  <description></description>
  
  
  <security_clearance>
    <allowed_paths>
      <path mode="read">frida-tasks/**</path>
      <path mode="read">contract/**</path>
      <path mode="read">schemas/**</path>
      <path mode="read">src/**</path>
      <path mode="read">templates/**</path>
      <path mode="read">README.md</path>
      <path mode="read">package.json</path>
      <path mode="read">.frida/AGENTS.md</path>
      <path mode="read">.frida/config.yaml</path>
      <path mode="read">.frida/templates/config.template.yaml</path>
      <path mode="read">.frida/contract/**</path>
      <path mode="read">.frida/reports/*.yaml</path>
      <path mode="read">AGENTS.md</path>
      <path mode="read">templates/AGENTS.md</path>
      <path mode="edit">contract/**</path>
      <path mode="edit">schemas/**</path>
      <path mode="edit">src/**</path>
      <path mode="edit">templates/**</path>
      <path mode="edit">README.md</path>
      <path mode="edit">package.json</path>
      <path mode="edit">frida-tasks/README.md</path>
    </allowed_paths>
    <create_allow>
      <path>.frida/reports/*.yaml</path>
    </create_allow>
    <forbidden_paths action="REDIRECT">
      <path>.frida/inbox/**</path>
      <path>tasks/**</path>
      <path mode="no-edit">.frida/**</path>
      <path mode="no-edit">frida-tasks/TASK-*.md</path>
      <path mode="no-edit">frida-tasks/**/TASK-*.md</path>
      <path mode="no-edit">tasks/**</path>
      <path mode="no-edit">.frida/reports/*.yaml</path>
    </forbidden_paths>
  </security_clearance>

  <invariants>
  </invariants>


  <workflow_constraints>
    <constraint>Do NOT hallucinate files outside of allowed_paths.</constraint>
    <constraint>Check invariants before outputting code.</constraint>
    <constraint>If path is forbidden, check for redirect before halting.</constraint>
  </workflow_constraints>
</agent_instruction>