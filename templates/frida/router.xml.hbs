<frida_router>
  <protocol>
    1. CHECK if user prompt contains an explicit selector token `profile:<id>`.
      1.1. If found: select the profile with matching id. If no profile matches → HALT with `no_profile_match`.
      1.2. If not found: proceed to step 2.
      2. ANALYZE user prompt for keywords.
      3. MATCH keywords to a <profile>.
        4. READ the file specified in 'context_path'.
        5. ADOPT the role and constraints.
        6. EXECUTE task.
  </protocol>

  <profiles>
    {{#each profiles}}
    <profile id="{{id}}">
      <role>{{role}}</role>
      <keywords>{{keywords}}</keywords>
      <context_path>.frida/contract/profiles/{{id}}.xml</context_path>
    </profile>
    {{/each}}
  </profiles>
</frida_router>