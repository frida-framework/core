<frida_router>
  <protocol>
    1. ANALYZE user prompt for keywords.
    2. MATCH keywords to a <profile>.
    3. READ the file specified in 'context_path'.
    4. ADOPT the role and constraints.
    5. EXECUTE task.
  </protocol>

  <profiles>
    {{#each profiles}}
    <profile id="{{id}}">
      <role>{{role}}</role>
      <keywords>{{keywords}}</keywords>
      <context_path>.specs/profiles/{{id}}.xml</context_path>
    </profile>
    {{/each}}
  </profiles>
</frida_router>