{
  "name": "@frida/core",
  "version": "0.1.0-alpha.0",
  "description": "Schema-driven Frida Core generation engine",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "frida-core": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./zone-check": {
      "types": "./dist/zone-check.d.ts",
      "import": "./dist/zone-check.js"
    },
    "./template-hash": {
      "types": "./dist/template-hash.d.ts",
      "import": "./dist/template-hash.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./schemas/frida-canon.schema.json": "./schemas/frida-canon.schema.json"
  },
  "files": [
    "dist",
    "schemas",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "prepack": "npm run clean && npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "handlebars": "^4.7.8",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "typescript": "^5.8.3"
  }
}
